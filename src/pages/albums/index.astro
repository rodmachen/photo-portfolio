---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AlbumCard from '../../components/AlbumCard.astro';
import { getCollection } from 'astro:content';

const albums = await getCollection('albums');
const photos = await getCollection('photos');

const sortedAlbums = albums.sort((a, b) => a.data.order - b.data.order);

function getPhotoCount(album: (typeof albums)[number]['data']): number {
  if (album.children) {
    return album.children.reduce(
      (sum, child) =>
        sum + photos.filter((p) => p.data.asset_folder === child.folder).length,
      0
    );
  }
  return photos.filter((p) => p.data.asset_folder === album.folder).length;
}
---

<BaseLayout title="Albums — Rod Machen Photography">
  <h1 class="page-title">Albums</h1>

  <section class="album-grid">
    {sortedAlbums.map((album) => (
      <AlbumCard
        slug={album.data.slug}
        title={album.data.title}
        cover={album.data.cover}
        photoCount={getPhotoCount(album.data)}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 480px) {
    .album-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
