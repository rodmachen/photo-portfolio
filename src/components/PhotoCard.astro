---
import { CldImage } from 'astro-cloudinary';
import { getCldImageUrl } from 'astro-cloudinary/helpers';

interface Props {
  publicId: string;
  width: number;
  height: number;
  alt?: string;
}

const { publicId, width, height, alt = '' } = Astro.props;

const fullUrl = getCldImageUrl({
  src: publicId,
  width: 1600,
  quality: 'auto',
  format: 'auto',
});
---

<div class="masonry-item">
  <a
    href={fullUrl}
    data-pswp-width={width}
    data-pswp-height={height}
    target="_blank"
  >
    <CldImage
      src={publicId}
      width={600}
      height={Math.round(600 * (height / width))}
      alt={alt}
      sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw"
      loading="lazy"
    />
  </a>
</div>
